# ============================================
# Login Register Backend - Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080

# ============================================
# Oracle Database Configuration
# ============================================
# Local Development
DB_URL=jdbc:oracle:thin:@localhost:1521:xe
DB_USERNAME=system
DB_PASSWORD=oracle

# Production (Replace with production values)
# DB_URL=jdbc:oracle:thin:@prod-host:1521:prod-db
# DB_USERNAME=prod_user
# DB_PASSWORD=prod_password

# ============================================
# JWT Configuration
# ============================================
# Generate a strong secret key (min 32 characters)
JWT_SECRET=mySecretKeyForJWTTokenGenerationAndValidationPurposeOnly1234567890
JWT_EXPIRATION_MS=86400000

# ============================================
# Spring Boot Profiles
# ============================================
SPRING_PROFILES_ACTIVE=dev

# ============================================
# Logging
# ============================================
LOG_LEVEL=DEBUG

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

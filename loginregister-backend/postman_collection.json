  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"phoneNumber\": \"1234567890\",\n  \"dateOfBirth\": \"1995-05-20\",\n  \"password\": \"Password@123\",\n  \"confirmPassword\": \"Password@123\",\n  \"favoriteColor\": \"Blue\",\n  \"nickName\": \"Johnny\",\n  \"petName\": \"Max\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
